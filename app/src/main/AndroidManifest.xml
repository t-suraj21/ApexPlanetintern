<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions needed to download dummy food images using Glide -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_foodiego_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_foodiego_logo"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.FoodieGo">

        <!-- Splash Screen Activity (Launcher) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FoodieGo.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Screen Activity -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.FoodieGo.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <!-- Register Screen Activity -->
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.FoodieGo.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <!-- Home Screen Activity -->
        <activity
            android:name=".activities.HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.FoodieGo.NoActionBar" />

        <!-- Food Details Screen Activity -->
        <activity
            android:name=".activities.FoodDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.FoodieGo.NoActionBar" />

        <!-- Cart Screen Activity -->
        <activity
            android:name=".activities.CartActivity"
            android:exported="false"
            android:theme="@style/Theme.FoodieGo.NoActionBar" />

        <!-- Profile Settings Activity -->
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.FoodieGo.NoActionBar"
            android:windowSoftInputMode="adjustPan" />

        <!-- Orders History Activity -->
        <activity
            android:name=".activities.OrdersActivity"
            android:exported="false"
            android:theme="@style/Theme.FoodieGo.NoActionBar" />

    </application>

</manifest>
