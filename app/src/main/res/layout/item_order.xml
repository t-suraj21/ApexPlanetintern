<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/grayBorder"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Order ID and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtOrderNumber"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Order #12345"
                android:textColor="@color/textDark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-bold" />

            <!-- Status Badge Wrapper -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="6dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/accentLight"
                app:contentPaddingLeft="8dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingTop="4dp"
                app:contentPaddingBottom="4dp">

                <TextView
                    android:id="@+id/txtOrderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textColor="@color/primaryColor"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Date & Time -->
        <TextView
            android:id="@+id/txtOrderDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="June 1, 2026 - 05:30 PM"
            android:textColor="@color/textGray"
            android:textSize="12sp"
            android:fontFamily="sans-serif" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@color/grayBorder" />

        <!-- Items Summary List -->
        <TextView
            android:id="@+id/txtOrderItemsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pizza Margherita x2, White Sauce Pasta x1"
            android:textColor="@color/textDark"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <!-- Total Cost -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="bottom">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Total Amount Paid"
                android:textColor="@color/textGray"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtOrderTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹399"
                android:textColor="@color/primaryColor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
